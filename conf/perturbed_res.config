params {
    step = "perturbed_res"
    fasta = "${projectDir}/assets/hg38_only_chromsomes.fa"
    fasta_index = "${projectDir}/assets/hg38_only_chromsomes.fa.fai"
    // 220k panel; CpG list matches the recall_0.77 reference matrix below.
    cpg_list = "/lustre1/cqyi/AIPT_2.0/data/meta/episcore/20260508-grid_search/recall_list/220k_cpg_recall_0.77.txt"
    snp_list = "${projectDir}/assets/snps_in_220kprobes_v2.tsv"
    reference_beta_zscore_matrix = "/lustre1/cqyi/syfan/nf_methylbert_infer/results/old_model_downsampled_episcore/output/threshold_0.67_recall_0.77/reference_beta_matrix_threshold_0.67_recall_0.77.tsv"
    // Read-probability threshold used to split the BAM (matches threshold_0.67).
    threshold = 0.67
    ncpgs = 0
    snp_depth_threshold = 30
    snp_est_mode = "all"
    beta_depth_threshold = 30
    report_allosomes = false
}
