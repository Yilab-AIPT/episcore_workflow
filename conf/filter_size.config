params {
    step = "split_bam"
    fasta = "${projectDir}/assets/hg38_only_chromsomes.fa"
    fasta_index = "${projectDir}/assets/hg38_only_chromsomes.fa.fai"
    cpg_list = "${projectDir}/assets/CpG_recall0.65.txt"
    snp_list = "${projectDir}/assets/snps_in_220kprobes_v2.tsv"
    reference_episcore_matrix = "${projectDir}/assets/early_reference_beta_zscore.tsv"
    threshold = 0
    ncpgs = 0
    snp_depth_threshold = 30
    snp_est_mode = "all"
    beta_depth_threshold = 30
}

process {
    withName: 'SPLIT_BAM_BY_DECONV_RES' {
        ext.args = '--size 150'
    }
}

executor {
    queueSize = 50
}